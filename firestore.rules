rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'facheritos@operlog.com.ar';
    }

    // Productos - cualquiera puede leer, solo admin escribe
    match /productos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Perfiles - cada usuario solo ve y edita el suyo
    match /perfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Pedidos
    match /pedidos/{id} {
      // Crear: permitido para todos (cliente/invitado), solo para transferencia (WhatsApp).
      // Pedidos MP se crean vía Cloud Function (crearPreferenciaMP) después de validar precios.
      // Lista blanca de campos + tipos + tamanos para frenar spam, payloads gigantes
      // e inyeccion de campos arbitrarios.
      allow create: if request.resource.data.estado == 'nuevo'
                    // total: numero positivo con tope sano (anti overflow / basura)
                    && request.resource.data.total is number
                    && request.resource.data.total > 0
                    && request.resource.data.total < 100000000
                    // items: lista no vacia, acotada
                    && request.resource.data.items is list
                    && request.resource.data.items.size() <= 200
                    // datos del cliente: tipos + tamanos
                    && request.resource.data.cliente_nombre is string
                    && request.resource.data.cliente_nombre.size() <= 200
                    && request.resource.data.metodo_pago == 'transferencia'
                    && (!('nota' in request.resource.data.keys())
                        || (request.resource.data.nota is string
                            && request.resource.data.nota.size() <= 2000))
                    // solo campos conocidos (lista blanca)
                    && request.resource.data.keys().hasOnly([
                         'usuario_id', 'es_invitado', 'cliente_nombre', 'cliente_email',
                         'cliente_telefono', 'cliente_direccion', 'items', 'total',
                         'metodo_pago', 'estado', 'nota', 'entrega', 'comprobante_url',
                         'seccion', 'creado', 'mp_preference_id', 'mp_payment_id',
                         'mp_collection_status'
                       ])
                    // un invitado no puede crear pedidos a nombre de otro usuario
                    && (
                         request.resource.data.usuario_id == null
                         || (request.auth != null && request.resource.data.usuario_id == request.auth.uid)
                       );
      // Leer: admin ve todos; usuario autenticado solo los suyos; invitados nunca
      allow read: if isAdmin()
                  || (request.auth != null && request.auth.uid == resource.data.usuario_id);
      // Modificar/eliminar: solo admin
      allow update, delete: if isAdmin();
    }

    // Config - cualquiera puede leer, solo admin escribe
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
